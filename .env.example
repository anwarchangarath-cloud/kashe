# Copy to .env.local and fill in. Firebase web config is public (safe in client).
VITE_FIREBASE_API_KEY=your-api-key
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_MESSAGING_SENDER_ID=000000000000
VITE_FIREBASE_APP_ID=1:000000000000:web:xxxxxxxxxxxx
VITE_FIREBASE_MEASUREMENT_ID=G-XXXXXXXXXX

# Base URL of your Cloudflare Worker API (products, cart, orders, coupons)
VITE_API_BASE=https://kash-api.your-subdomain.workers.dev
